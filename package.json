    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.20.0",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-write-stream": "^2.0.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.9.1",
    "node-cron": "^3.0.0",
    "p-limit": "^3.1.0",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "playwright": "^1.47.0",
    "socket.io": "^4.8.3",
