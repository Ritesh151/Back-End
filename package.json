    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
